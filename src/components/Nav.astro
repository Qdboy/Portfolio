---
import { site } from '../data/site.config';
---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4" id="nav">
  <a
    href="/"
    class="font-serif text-lg tracking-widest uppercase"
    style="color: var(--color-gold)"
  >
    QB
  </a>

  <ul class="hidden md:flex gap-8 text-sm tracking-wider text-stone-400 uppercase">
    {(['About', 'Projects', 'Skills', 'Experience', 'Contact'] as const).map((label) => (
      <li>
        <a
          href={`#${label.toLowerCase()}`}
          class="hover:text-[--color-gold] transition-colors duration-300"
        >
          {label}
        </a>
      </li>
    ))}
  </ul>

  {site.availableForWork && (
    <div class="flex items-center gap-2 text-xs tracking-wider text-stone-400">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background: var(--color-gold)" />
        <span class="relative inline-flex rounded-full h-2 w-2" style="background: var(--color-gold)" />
      </span>
      Available for freelance
    </div>
  )}
</nav>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  });
</script>

<style>
  #nav {
    transition: background 0.3s, backdrop-filter 0.3s, border-color 0.3s;
    border-bottom: 1px solid transparent;
  }
  #nav.nav-scrolled {
    background: rgba(13, 11, 8, 0.85);
    backdrop-filter: blur(12px);
    border-color: rgba(201, 168, 76, 0.15);
  }
</style>
